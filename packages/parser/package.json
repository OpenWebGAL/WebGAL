  "license": "MPL-2.0",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^23.0.2",
    "@rollup/plugin-node-resolve": "^15.0.1",
    "@types/node": "^18.14.0",
    "@vitest/coverage-c8": "^0.28.5",
    "rimraf": "^3.0.2",
    "rollup": "^3.29.5",
    "rollup-plugin-typescript2": "^0.34.1",
    "tslib": "^2.4.1",
    "tsx": "^3.12.7",
    "typescript": "^4.9.3",
    "vitest": "^0.28.5"
  },
  "type": "module"
